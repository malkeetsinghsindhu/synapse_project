						"source": [
							"bronze_df = sales_df \\\n",
							"    .withColumn(\"file_path\", input_file_name()) \\\n",
							"    .withColumn(\"last_update_ts\", current_timestamp())\n",
							"\n",
							"display(bronze_df)"
						],
						"outputs": [],
						"execution_count": 11
					},
					{
						"cell_type": "code",
						"metadata": {},
						"source": [
							"bronze_df.write.format(\"delta\") \\\n",
							"    .mode(\"overwrite\") \\\n",
							"    .option(\"overwriteSchema\", \"true\") \\\n",
							"    .save(\"abfss://bronze@etldevstorage1.dfs.core.windows.net/sales/\")\n",
							"\n",
							"print(\"✅ Data written successfully!\")"
						],
						"outputs": [],
						"execution_count": 12
					},
					{
						"cell_type": "code",
						"metadata": {
							"collapsed": false
						},
						"source": [
							"# Cell 1 - Read\n",
							"from pyspark.sql.functions import input_file_name, current_timestamp\n",
							"\n",
							"sales_orders_df = spark.read.format(\"csv\") \\\n",
							"    .option(\"header\", \"true\") \\\n",
							"    .option(\"inferSchema\", \"true\") \\\n",
							"    .load(\"abfss://retail-data@etldevstorage1.dfs.core.windows.net/sales_orders/*\")\n",
							"\n",
							"display(sales_orders_df)"
						],
						"outputs": [],
						"execution_count": 14
					},
					{
						"cell_type": "code",
						"metadata": {
							"collapsed": false
						},
						"source": [
							"# Cell 2 - Add metadata\n",
							"bronze_df = sales_orders_df \\\n",
							"    .withColumn(\"file_path\", input_file_name()) \\\n",
							"    .withColumn(\"last_update_ts\", current_timestamp())\n",
							"\n",
							"display(bronze_df)"
						],
						"outputs": [],
						"execution_count": 15
					},
					{
						"cell_type": "code",
						"metadata": {},
						"source": [
							"# Cell 3 - Write to bronze\n",
							"bronze_df.write.format(\"delta\") \\\n",
							"    .mode(\"overwrite\") \\\n",
							"    .option(\"overwriteSchema\", \"true\") \\\n",
							"    .save(\"abfss://bronze@etldevstorage1.dfs.core.windows.net/sales_orders/\")\n",
							"\n",
							"print(\"✅ Data written successfully!\")"
						],
						"outputs": [],
						"execution_count": 16
					},
					{
						"cell_type": "code",
