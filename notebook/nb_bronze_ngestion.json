		"cells": [
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"from pyspark.sql.functions import *\n",
					"from pyspark.sql.types import *\n",
					"\n",
					"customers_df = spark.read.format(\"csv\") \\\n",
					"    .option(\"header\", \"true\") \\\n",
					"    .option(\"inferSchema\", \"true\") \\\n",
					"    .load(\"abfss://retail-data@etldevstorage1.dfs.core.windows.net/customers/*\")\n",
					"\n",
					"display(customers_df)"
				],
				"execution_count": 1
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"bronze_df = customers_df \\\n",
					"    .withColumn(\"file_path\", input_file_name()) \\\n",
					"    .withColumn(\"last_update_ts\", current_timestamp())\n",
					"\n",
					"display(bronze_df)"
				],
				"execution_count": 2
			},
			{
				"cell_type": "code",
				"source": [
					"bronze_df.write.format(\"delta\") \\\n",
					"    .mode(\"overwrite\") \\\n",
					"    .option(\"overwriteSchema\", \"true\") \\\n",
					"    .save(\"abfss://bronze@etldevstorage1.dfs.core.windows.net/customers/\")\n",
					"\n",
					"print(\"✅ Data written successfully!\")"
				],
				"execution_count": 5
			}
		]
	}
